# 이 파일을 .env로 복사하고 키를 채우세요. (.env는 gitignore됨)

# LLM 프로바이더: github | gemini
LLM_PROVIDER=github

# GitHub Models(무료): https://github.com/settings/personal-access-tokens (Account permissions › Models: Read-only)
GITHUB_TOKEN=여기에_토큰

# Google Gemini(무료): https://aistudio.google.com/apikey
GEMINI_API_KEY=여기에_키

# 네이버 뉴스 검색 API(무료): https://developers.naver.com/apps → 검색 API 등록
NAVER_CLIENT_ID=여기에_client_id
NAVER_CLIENT_SECRET=여기에_client_secret
